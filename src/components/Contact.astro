---
---
<section id="contact">
  <div class="inner">
    <h2>お問い合わせ</h2>
    <p class="lead">ご質問・ご相談はお気軽にどうぞ。</p>
    <form>
      <div class="field">
        <label for="name">お名前</label>
        <input type="text" id="name" name="name" placeholder="山田 太郎" required />
      </div>
      <div class="field">
        <label for="email">メールアドレス</label>
        <input type="email" id="email" name="email" placeholder="example@email.com" required />
      </div>
      <div class="field">
        <label for="message">メッセージ</label>
        <textarea id="message" name="message" rows="6" placeholder="お問い合わせ内容をご記入ください。" required></textarea>
      </div>
      <button type="submit">送信する</button>
    </form>
  </div>
</section>

<style>
  section {
    background: #1a1a2e;
    padding: 5rem 2rem;
    color: white;
  }
  .inner {
    max-width: 600px;
    margin: 0 auto;
  }
  h2 {
    font-size: 2rem;
    text-align: center;
    margin-bottom: 0.75rem;
  }
  .lead {
    text-align: center;
    color: #aaa;
    margin-bottom: 2.5rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }
  label {
    font-size: 0.9rem;
    color: #ccc;
  }
  input,
  textarea {
    background: #0f0f1a;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: white;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }
  input::placeholder,
  textarea::placeholder {
    color: #555;
  }
  input:focus,
  textarea:focus {
    border-color: #e94560;
  }
  button {
    display: block;
    width: 100%;
    padding: 0.9rem;
    background: #e94560;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  button:hover {
    opacity: 0.85;
  }
</style>
