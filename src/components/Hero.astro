---
interface Props {
  title: string;
  subtitle: string;
  cta: string;
}

const { title, subtitle, cta } = Astro.props;
---
<section>
  <h1 set:html={title}></h1>
  <p>{subtitle}</p>
  <a href="#">{cta}</a>
</section>

<style>
  section {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    color: white;
    padding: 2rem;
  }
  h1 {
    font-size: 3rem;
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  p {
    font-size: 1.2rem;
    color: #aaa;
    margin-bottom: 2rem;
  }
  a {
    background: #e94560;
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
  }
</style>